#!/bin/bash

GREEN='\033[0;32m'
RED='\033[0;31m'
YELLOW='\033[1;33m'
BLUE='\033[0;34m'
NC='\033[0m'

APP_NAME="DeskController.app"
APPS_DIR="/Applications"
LOG_DIR="$HOME/Library/Logs"
LINAK_CONFIG_DIR="$HOME/Library/Application Support/linak-controller"

# Echo functions
print_header() {
    echo -e "\n${BLUE}━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━${NC}"
    echo -e "${BLUE}$1${NC}"
    echo -e "${BLUE}━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━${NC}"
}

print_success() {
    echo -e "${GREEN}✓ $1${NC}"
}

print_error() {
    echo -e "${RED}✗ $1${NC}"
}

print_warning() {
    echo -e "${YELLOW}⚠ $1${NC}"
}

print_info() {
    echo -e "${BLUE}ℹ $1${NC}"
}

# Prompt for yes/no confirmation. Returns 0 for yes, 1 for no.
confirm() {
    read -p "$1 (y/n) " -n 1 -r
    echo
    [[ $REPLY =~ ^[Yy]$ ]]
}

# Remove the .app bundle from /Applications
remove_app() {
    print_header "Removing $APP_NAME"

    if [ ! -d "$APPS_DIR/$APP_NAME" ]; then
        print_warning "$APP_NAME not found at $APPS_DIR — nothing to remove"
        return 0
    fi

    if sudo rm -rf "$APPS_DIR/$APP_NAME"; then
        print_success "$APP_NAME removed from $APPS_DIR"
    else
        print_error "Failed to remove $APP_NAME"
        return 1
    fi
}

# Remove DeskController log files
remove_logs() {
    local runtime_log="$LOG_DIR/DeskController.log"
    local error_log="$LOG_DIR/DeskController_error.log"

    if [ ! -f "$runtime_log" ] && [ ! -f "$error_log" ]; then
        return 0
    fi

    if confirm "Remove DeskController log files at $LOG_DIR?"; then
        rm -f "$runtime_log" "$error_log"
        print_success "Log files removed"
    else
        print_info "Log files preserved"
    fi
}

# Optionally uninstall linak-controller and its config
remove_linak_controller() {
    if ! command -v linak-controller &> /dev/null; then
        print_info "linak-controller not found — skipping"
        return 0
    fi

    print_warning "linak-controller is a standalone tool that may be used outside DeskController"
    if ! confirm "Uninstall linak-controller?"; then
        print_info "Keeping linak-controller"
        return 0
    fi

    if pip3 uninstall -y linak-controller; then
        print_success "linak-controller uninstalled"
    else
        print_error "Failed to uninstall linak-controller (try pipx uninstall linak-controller if installed via pipx)"
    fi

    if [ -d "$LINAK_CONFIG_DIR" ]; then
        if confirm "Also remove linak-controller config at $LINAK_CONFIG_DIR?"; then
            rm -rf "$LINAK_CONFIG_DIR"
            print_success "linak-controller config removed"
        else
            print_info "Config preserved"
        fi
    fi
}

# Optionally uninstall PyObjC
remove_pyobjc() {
    if ! python3 -c "import objc" 2>/dev/null; then
        return 0
    fi

    print_warning "PyObjC may be required by other Python apps on this system"
    if ! confirm "Uninstall PyObjC?"; then
        print_info "Keeping PyObjC"
        return 0
    fi

    if pip3 uninstall -y pyobjc pyobjc-core; then
        print_success "PyObjC uninstalled"
    else
        print_error "Failed to uninstall PyObjC"
    fi
}

# Optionally uninstall Homebrew (destructive — affects entire system)
remove_homebrew() {
    if ! command -v brew &> /dev/null; then
        return 0
    fi

    print_warning "Uninstalling Homebrew will remove ALL Homebrew-installed packages"
    print_warning "This affects software completely unrelated to DeskController"

    if ! confirm "Uninstall Homebrew?"; then
        print_info "Keeping Homebrew"
        return 0
    fi

    if ! confirm "Are you absolutely sure? This is destructive and irreversible."; then
        print_info "Keeping Homebrew"
        return 0
    fi

    print_info "Running the official Homebrew uninstaller..."
    if /bin/bash -c "$(curl -fsSL https://raw.githubusercontent.com/Homebrew/install/HEAD/uninstall.sh)"; then
        print_success "Homebrew uninstalled"
    else
        print_error "Homebrew uninstaller exited with an error"
    fi
}

main() {
    print_header "DeskController Uninstaller"

    remove_app || exit 1
    remove_logs

    print_header "Optional dependency cleanup"
    print_info "The following were installed by ./install. You can remove or keep each."

    remove_linak_controller
    remove_pyobjc
    remove_homebrew

    print_header "Uninstall complete"
    print_success "DeskController removed"
}

main
